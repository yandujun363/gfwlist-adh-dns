{
  "dns": {
    "hosts": {
      "dns.hinet.net": [
        "168.95.1.1",
        "168.95.192.1",
        "2001:b000:168::1",
        "2001:b000:168::2"
      ],
      "dns.twnic.tw": ["2001:de4::102", "101.102.103.104"],
      "dns.google": ["8.8.8.8", "8.8.4.4"],
      "dns.cloudflare.com": [
        "1.1.1.1",
        "1.0.0.1",
        "2606:4700:4700::1111",
        "2606:4700:4700::1001"
      ]
    },
    "tag":"dns"
  },
  "inbounds": [
    {
      "listen": "127.0.0.2",
      "port": 5533,
      "protocol": "tunnel",
      "settings": {
        "allowedNetwork": "tcp"
      },
      "tag": "dns-in"
    }
  ],
  "outbounds": [
    {
      "protocol": "freedom",
      "settings": {
        "domainStrategy": "UseIP",
        "redirect": "dns.hinet.net:53",
        "fragment": {
          "packets": "1-3",
          "length": "10",
          "interval": 0
        }
      },
      "tag": "dns-out-1"
    },
    {
      "protocol": "freedom",
      "settings": {
        "domainStrategy": "UseIP",
        "redirect": "dns.twnic.tw:53",
        "fragment": {
          "packets": "1-3",
          "length": "10",
          "interval": 0
        }
      },
      "tag": "dns-out-2"
    },
    {
      "protocol": "freedom",
      "settings": {
        "domainStrategy": "UseIP",
        "redirect": "dns.google:53",
        "fragment": {
          "packets": "1-3",
          "length": "10",
          "interval": 0
        }
      },
      "tag": "dns-out-3"
    },
    {
      "protocol": "freedom",
      "settings": {
        "domainStrategy": "UseIP",
        "redirect": "dns.cloudflare.com:53",
        "fragment": {
          "packets": "1-3",
          "length": "10",
          "interval": 0
        }
      },
      "tag": "dns-out-4"
    }
  ],
  "routing":{
    "domainStrategy":"AsIs",
    "rules":[
        {
            "inboundTag": ["dns-in"],
            "balancerTag": "dns-balancer"
        }
    ],
    "balancers":[
        {
            "tag": "dns-balancer",
            "selector": [
                "dns-out-"
            ],
            "strategy": "roundRobin"
        }
    ]
  }
}
